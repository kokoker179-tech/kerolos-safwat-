{
  "entities": {
    "booking": {
      "title": "Booking",
      "description": "Represents a graduation party reservation.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the person booking." },
        "year": { "type": "string", "description": "The academic year." },
        "phone": { "type": "string", "description": "The phone number." },
        "gender": { "type": "string", "description": "The gender." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of creation." },
        "eventId": { "type": "string", "description": "Identifier for the event." }
      },
      "required": ["name", "phone", "createdAt", "eventId"]
    }
  },
  "firestore": {
    "/bookings/{bookingId}": {
      "schema": { "$ref": "booking" },
      "description": "Bookings for the graduation party."
    }
  }
}
